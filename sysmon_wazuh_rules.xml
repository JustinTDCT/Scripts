    <if_matched_group>discovery</if_matched_group>
    <same_field>win.system.computer</same_field>
    <description>BEHAVIORAL: Rapid enumeration burst (5+ recon commands in 3min) on $(win.system.computer)</description>
    <mitre>
      <id>T1082</id>
      <id>T1016</id>
      <id>T1087</id>
    </mitre>
    <group>enumeration_burst,high_confidence,</group>
  </rule>

  <!-- Multiple Office-spawned processes (active exploitation) -->
  <rule id="100201" level="14" frequency="3" timeframe="300">
    <if_matched_group>office_macro</if_matched_group>
    <same_field>win.system.computer</same_field>
    <description>CRITICAL: Multiple processes spawned by Office on $(win.system.computer) - active exploitation</description>
    <mitre>
      <id>T1204.002</id>
    </mitre>
    <group>active_exploitation,high_confidence,</group>
  </rule>

  <!-- Multiple LOLBin network connections from same host -->
  <rule id="100202" level="12" frequency="3" timeframe="300">
    <if_matched_group>lolbin_network</if_matched_group>
    <same_field>win.system.computer</same_field>
    <description>BEHAVIORAL: Multiple LOLBin network connections on $(win.system.computer) - possible staging/C2</description>
    <mitre>
