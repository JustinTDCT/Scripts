<!--
================================================================================
  WAZUH CUSTOM RULES - SYSMON BEHAVIORAL DETECTIONS
================================================================================
  Version:        2026.03.23
  Compatible:     Wazuh 4.x with Sysmon 15.x+ (schema 4.90)
  Rule ID Range:  100001 - 100200
  Purpose:        Behavioral detection rules for Sysmon telemetry that
                  replicate Huntress Process Insights-style alerting.

  DEPLOYMENT:
    Option A (UI):  Wazuh Dashboard > Management > Rules > "Add new rules file"
                    Upload this file, then restart the manager.
    Option B (CLI): Copy to /var/ossec/etc/rules/local_rules.xml (append)
                    or save as a standalone file in /var/ossec/etc/rules/
                    then restart:  systemctl restart wazuh-manager

  DEPENDENCIES:
    These rules are CHILD rules of the stock Wazuh Sysmon rules in
    0595-win-sysmon_rules.xml (rule IDs 61600-61640).  The stock rules
    MUST remain enabled — they decode Sysmon fields that these rules
    match against.

  PARENT RULE REFERENCE:
    61603 = Sysmon Event 1  (Process Creation)
    61604 = Sysmon Event 2  (File Creation Time Changed)
    61605 = Sysmon Event 3  (Network Connection)
    61606 = Sysmon Event 4  (Sysmon Service State Changed)
    61607 = Sysmon Event 5  (Process Terminated)
    61608 = Sysmon Event 6  (Driver Loaded)
    61609 = Sysmon Event 7  (Image Loaded)
    61610 = Sysmon Event 8  (CreateRemoteThread)
    61611 = Sysmon Event 9  (RawAccessRead)
    61612 = Sysmon Event 10 (ProcessAccess)
    61613 = Sysmon Event 11 (FileCreate)
    61614 = Sysmon Event 12/13/14 (Registry Events)
    61625 = Sysmon Event 22 (DNS Query)

  TUNING:
    After deployment, watch for false positives over 48-72 hours.
    Use <if_sid>RULE_ID</if_sid> with level="0" to suppress noisy
    rules, or add environment-specific negate patterns.

  MITRE ATT&CK:
    All rules are tagged with relevant technique IDs.
================================================================================
-->


<!-- ============================================================ -->
<!-- PROCESS CREATION DETECTIONS (Sysmon Event ID 1)              -->
<!-- ============================================================ -->

<group name="sysmon,process_creation,">

  <!-- ==================== -->
  <!-- BASE PROCESS RULE    -->
  <!-- ==================== -->

  <rule id="100001" level="3">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image">\.+</field>
    <description>Sysmon: Process Created - $(win.eventdata.image)</description>
    <group>sysmon_event1,</group>
    <options>no_full_log</options>
  </rule>

  <!-- ======================================== -->
  <!-- SUSPICIOUS PARENT-CHILD RELATIONSHIPS    -->
  <!-- ======================================== -->

  <!-- cmd.exe spawned by Microsoft Office -->
  <rule id="100010" level="12">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(winword|excel|powerpnt|outlook|msaccess|onenote)\.exe$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\cmd\.exe$</field>
    <description>SUSPICIOUS: cmd.exe spawned by Office application $(win.eventdata.parentImage)</description>
    <mitre>
      <id>T1059.003</id>
      <id>T1204.002</id>
    </mitre>
    <group>suspicious_parent_child,office_macro,</group>
  </rule>

  <!-- PowerShell spawned by Microsoft Office -->
  <rule id="100011" level="12">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(winword|excel|powerpnt|outlook|msaccess)\.exe$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(powershell|pwsh)\.exe$</field>
    <description>SUSPICIOUS: PowerShell spawned by Office application $(win.eventdata.parentImage)</description>
    <mitre>
      <id>T1059.001</id>
      <id>T1204.002</id>
    </mitre>
    <group>suspicious_parent_child,office_macro,</group>
  </rule>

  <!-- wscript/cscript spawned by Office -->
  <rule id="100012" level="12">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(winword|excel|powerpnt|outlook)\.exe$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(wscript|cscript)\.exe$</field>
    <description>SUSPICIOUS: Script host spawned by Office - $(win.eventdata.image) from $(win.eventdata.parentImage)</description>
    <mitre>
      <id>T1059.005</id>
      <id>T1204.002</id>
    </mitre>
    <group>suspicious_parent_child,office_macro,</group>
  </rule>

  <!-- Shell spawned by web server processes (webshell indicator) -->
  <rule id="100013" level="14">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(w3wp|httpd|nginx|tomcat\d*|java)\.exe$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(cmd|powershell|pwsh)\.exe$</field>
    <description>HIGH: Shell spawned by web server process - possible webshell $(win.eventdata.parentImage) -> $(win.eventdata.image)</description>
    <mitre>
      <id>T1505.003</id>
      <id>T1059</id>
    </mitre>
    <group>webshell,suspicious_parent_child,</group>
  </rule>

  <!-- explorer.exe spawned by cmd/powershell (masquerading) -->
  <rule id="100014" level="10">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(cmd|powershell|regsvr32)\.exe$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\explorer\.exe$</field>
    <description>SUSPICIOUS: explorer.exe spawned by $(win.eventdata.parentImage) - possible masquerading</description>
    <mitre>
      <id>T1036</id>
    </mitre>
    <group>suspicious_parent_child,masquerading,</group>
  </rule>

  <!-- Shell spawned by scripting hosts (second-stage execution) -->
  <rule id="100015" level="10">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(wscript|cscript|mshta)\.exe$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(cmd|powershell|pwsh)\.exe$</field>
    <description>SUSPICIOUS: Shell spawned by script host $(win.eventdata.parentImage) -> $(win.eventdata.image)</description>
    <mitre>
      <id>T1059</id>
    </mitre>
    <group>suspicious_parent_child,script_execution,</group>
  </rule>

  <!-- Process spawned by WMI (wmiprvse) -->
  <rule id="100016" level="8">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\wmiprvse\.exe$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(cmd|powershell|pwsh|mshta|regsvr32|rundll32|certutil|bitsadmin)\.exe$</field>
    <description>SUSPICIOUS: $(win.eventdata.image) spawned by WMI provider host</description>
    <mitre>
      <id>T1047</id>
    </mitre>
    <group>suspicious_parent_child,wmi_execution,</group>
  </rule>

  <!-- Process spawned by Task Scheduler engine -->
  <rule id="100017" level="6">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(taskeng|schtasks|taskhostw)\.exe$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(cmd|powershell|pwsh|mshta|wscript|cscript|regsvr32|rundll32)\.exe$</field>
    <description>Scheduled task executing $(win.eventdata.image) via $(win.eventdata.parentImage)</description>
    <mitre>
      <id>T1053.005</id>
    </mitre>
    <group>suspicious_parent_child,scheduled_task_exec,</group>
  </rule>

  <!-- ======================================== -->
  <!-- LOLBIN / LIVING OFF THE LAND DETECTIONS  -->
  <!-- ======================================== -->

  <!-- certutil.exe downloading or decoding content -->
  <rule id="100020" level="12">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\certutil\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(urlcache|split|decode|encode|decodehex|-f\s+http)</field>
    <description>LOLBin: certutil.exe used for download/decode - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1105</id>
      <id>T1140</id>
    </mitre>
    <group>lolbin,ingress_tool_transfer,</group>
  </rule>

  <!-- bitsadmin file transfer -->
  <rule id="100021" level="10">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\bitsadmin\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(transfer|download|upload|addfile)</field>
    <description>LOLBin: bitsadmin used for file transfer - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1197</id>
      <id>T1105</id>
    </mitre>
    <group>lolbin,ingress_tool_transfer,</group>
  </rule>

  <!-- mshta.exe execution with remote or script content -->
  <rule id="100022" level="10">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\mshta\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(http|vbscript|javascript|about:)</field>
    <description>LOLBin: mshta.exe executing remote/script content - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1218.005</id>
    </mitre>
    <group>lolbin,proxy_execution,</group>
  </rule>

  <!-- regsvr32 proxy execution (Squiblydoo and variants) -->
  <rule id="100023" level="12">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\regsvr32\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(/s\s+/n\s+/u\s+/i:|scrobj\.dll|http)</field>
    <description>LOLBin: regsvr32 proxy execution (Squiblydoo) - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1218.010</id>
    </mitre>
    <group>lolbin,proxy_execution,</group>
  </rule>

  <!-- rundll32 executing unusual content -->
  <rule id="100024" level="10">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\rundll32\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(javascript|http|comsvcs|davclnt|pcwutl|zipfldr|advpack|ieadvpack|setupapi|shdocvw|shell32.*ShellExec_RunDLL)</field>
    <description>LOLBin: rundll32 suspicious execution - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1218.011</id>
    </mitre>
    <group>lolbin,proxy_execution,</group>
  </rule>

  <!-- wmic process creation or remote execution -->
  <rule id="100025" level="10">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\wmic\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(process\s+call\s+create|/node:|shadowcopy\s+delete)</field>
    <description>LOLBin: wmic suspicious usage - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1047</id>
    </mitre>
    <group>lolbin,wmi_abuse,</group>
  </rule>

  <!-- pcalua.exe proxy execution -->
  <rule id="100026" level="12">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\pcalua\.exe$</field>
    <description>LOLBin: pcalua.exe (Program Compatibility Assistant) execution - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1218</id>
    </mitre>
    <group>lolbin,proxy_execution,</group>
  </rule>

  <!-- msiexec installing from remote URL -->
  <rule id="100027" level="10">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\msiexec\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(http|/q.*http|/q.*\\\\)</field>
    <description>LOLBin: msiexec remote package install - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1218.007</id>
    </mitre>
    <group>lolbin,proxy_execution,</group>
  </rule>

  <!-- installutil / msbuild proxy execution (.NET LOLBins) -->
  <rule id="100028" level="12">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(InstallUtil|MSBuild|cmstp|xwizard|ieexec|dnscmd)\.exe$</field>
    <description>LOLBin: .NET/system proxy execution via $(win.eventdata.image) - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1218</id>
    </mitre>
    <group>lolbin,proxy_execution,</group>
  </rule>

  <!-- ======================================== -->
  <!-- POWERSHELL SUSPICIOUS PATTERNS           -->
  <!-- ======================================== -->

  <!-- Encoded PowerShell command -->
  <rule id="100030" level="12">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(powershell|pwsh)\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(-enc\s|-encodedcommand\s|-ec\s)</field>
    <description>PowerShell: Encoded command execution - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1059.001</id>
      <id>T1027</id>
    </mitre>
    <group>powershell_suspicious,encoded_command,</group>
  </rule>

  <!-- PowerShell download cradle patterns -->
  <rule id="100031" level="12">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(powershell|pwsh)\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(iex|invoke-expression|downloadstring|downloadfile|invoke-webrequest|iwr\s|net\.webclient|bitstransfer|start-bitstransfer)</field>
    <description>PowerShell: Download cradle detected - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1059.001</id>
      <id>T1105</id>
    </mitre>
    <group>powershell_suspicious,download_cradle,</group>
  </rule>

  <!-- PowerShell AMSI bypass -->
  <rule id="100032" level="14">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(amsiutils|amsiinitfailed|amsi\.dll|SetProtection|AmsiScanBuffer|amsiContext)</field>
    <description>CRITICAL: AMSI bypass attempt detected - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1562.001</id>
    </mitre>
    <group>powershell_suspicious,defense_evasion,</group>
  </rule>

  <!-- PowerShell execution policy bypass -->
  <rule id="100033" level="8">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(powershell|pwsh)\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(-exec\s+bypass|-executionpolicy\s+bypass|set-executionpolicy\s+unrestricted)</field>
    <description>PowerShell: Execution policy bypass - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
    <group>powershell_suspicious,</group>
  </rule>

  <!-- PowerShell with hidden window (stealth execution) -->
  <rule id="100034" level="10">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(powershell|pwsh)\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(-w\s+hidden|-windowstyle\s+hidden|-w\s+1|-nop\s+-w\s+h)</field>
    <description>PowerShell: Hidden window execution - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1059.001</id>
      <id>T1564</id>
    </mitre>
    <group>powershell_suspicious,hidden_execution,</group>
  </rule>

  <!-- PowerShell reflection/assembly loading (C# in-memory execution) -->
  <rule id="100035" level="12">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(Reflection\.Assembly|Load\(\[|FromBase64String|CompileAssemblyFromSource|Add-Type.*DllImport|P/Invoke)</field>
    <description>PowerShell: Reflection/Assembly loading detected - possible in-memory execution</description>
    <mitre>
      <id>T1059.001</id>
      <id>T1620</id>
    </mitre>
    <group>powershell_suspicious,reflective_loading,</group>
  </rule>

  <!-- ======================================== -->
  <!-- CREDENTIAL ACCESS DETECTIONS             -->
  <!-- ======================================== -->

  <!-- Registry credential dumping (SAM/SECURITY/SYSTEM) -->
  <rule id="100040" level="14">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(reg\s+save\s+hklm\\(sam|security|system)|sekurlsa|lsadump|mimikatz|procdump.*lsass|comsvcs.*MiniDump)</field>
    <description>CRITICAL: Credential dumping attempt - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1003.002</id>
      <id>T1003.001</id>
    </mitre>
    <group>credential_access,credential_dump,</group>
  </rule>

  <!-- ntdsutil for AD database extraction -->
  <rule id="100041" level="14">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\ntdsutil\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(ifm|create\s+full|ac\s+i\s+ntds)</field>
    <description>CRITICAL: ntdsutil AD database extraction attempt - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1003.003</id>
    </mitre>
    <group>credential_access,ad_dump,</group>
  </rule>

  <!-- Shadow copy operations (often precedes credential dump) -->
  <rule id="100042" level="10">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\vssadmin\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(create\s+shadow|delete\s+shadows)</field>
    <description>Shadow copy manipulation: $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1003.003</id>
      <id>T1490</id>
    </mitre>
    <group>credential_access,shadow_copy,</group>
  </rule>

  <!-- ======================================== -->
  <!-- LATERAL MOVEMENT INDICATORS              -->
  <!-- ======================================== -->

  <!-- PsExec-style remote execution -->
  <rule id="100050" level="10">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(psexesvc|PSEXESVC)\.exe$</field>
    <description>Lateral Movement: Process spawned by PsExec service - $(win.eventdata.image)</description>
    <mitre>
      <id>T1021.002</id>
      <id>T1569.002</id>
    </mitre>
    <group>lateral_movement,remote_execution,</group>
  </rule>

  <!-- Remote service creation via sc.exe -->
  <rule id="100051" level="10">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\sc\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(\\\\.*\s+create|\\\\.*\s+start|\\\\.*\s+config)</field>
    <description>Lateral Movement: Remote service manipulation via sc.exe - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1021.002</id>
      <id>T1543.003</id>
    </mitre>
    <group>lateral_movement,service_abuse,</group>
  </rule>

  <!-- Remote schtasks creation -->
  <rule id="100052" level="10">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\schtasks\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)/create.*\s+/s\s+</field>
    <description>Lateral Movement: Remote scheduled task creation - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1053.005</id>
      <id>T1021</id>
    </mitre>
    <group>lateral_movement,remote_schtask,</group>
  </rule>

  <!-- ======================================== -->
  <!-- PERSISTENCE DETECTIONS                   -->
  <!-- ======================================== -->

  <!-- Scheduled task creation (local) -->
  <rule id="100060" level="8">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\schtasks\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)/create</field>
    <description>Persistence: Scheduled task created - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1053.005</id>
    </mitre>
    <group>persistence,scheduled_task,</group>
  </rule>

  <!-- Registry Run key modification via reg.exe -->
  <rule id="100061" level="10">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\reg\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(add\s+.*\\(Run|RunOnce)\s|add\s+.*\\CurrentVersion\\(Run|RunOnce))</field>
    <description>Persistence: Registry Run key modified via reg.exe - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1547.001</id>
    </mitre>
    <group>persistence,registry_run,</group>
  </rule>

  <!-- New service creation via sc.exe -->
  <rule id="100062" level="8">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\sc\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\s+create\s+</field>
    <description>Persistence: New service created via sc.exe - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1543.003</id>
    </mitre>
    <group>persistence,new_service,</group>
  </rule>

  <!-- ======================================== -->
  <!-- DEFENSE EVASION                          -->
  <!-- ======================================== -->

  <!-- Windows Defender tampering -->
  <rule id="100070" level="12">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(Set-MpPreference\s+.*-Disable|Add-MpPreference\s+.*-ExclusionPath|DisableRealtimeMonitoring|DisableBehaviorMonitoring|DisableIOAVProtection)</field>
    <description>Defense Evasion: Windows Defender tampering - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1562.001</id>
    </mitre>
    <group>defense_evasion,av_tampering,</group>
  </rule>

  <!-- Event log clearing -->
  <rule id="100071" level="14">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\wevtutil\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(cl\s|clear-log)</field>
    <description>CRITICAL: Event log clearing detected - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1070.001</id>
    </mitre>
    <group>defense_evasion,log_clearing,</group>
  </rule>

  <!-- Audit policy tampering -->
  <rule id="100072" level="12">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\auditpol\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(disable|/remove|/clear)</field>
    <description>Defense Evasion: Audit policy tampering - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1562.002</id>
    </mitre>
    <group>defense_evasion,audit_tampering,</group>
  </rule>

  <!-- Executable running from suspicious user-writable path -->
  <rule id="100073" level="8">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\Users\\[^\\]+\\(AppData\\Local\\Temp|Downloads|Desktop|Documents)\\[^\\]+\.exe$</field>
    <field name="win.eventdata.image" type="pcre2" negate="yes">(?i)\\(chrome|firefox|teams|slack|discord|vscode|code|zoom|onedrive|msedge|brave|setup|update)</field>
    <description>Suspicious: Executable running from user temp/downloads - $(win.eventdata.image)</description>
    <mitre>
      <id>T1204.002</id>
    </mitre>
    <group>suspicious_location,</group>
  </rule>

  <!-- Firewall rule manipulation -->
  <rule id="100074" level="10">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\netsh\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(firewall\s+.*\s+rule\s+.*\s+add|advfirewall\s+.*\s+add|firewall\s+set\s+opmode\s+disable)</field>
    <description>Defense Evasion: Firewall rule modification - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1562.004</id>
    </mitre>
    <group>defense_evasion,firewall_tampering,</group>
  </rule>

  <!-- Timestomping via PowerShell -->
  <rule id="100075" level="12">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(CreationTime|LastWriteTime|LastAccessTime)\s*=</field>
    <description>Defense Evasion: Possible timestomping via PowerShell - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1070.006</id>
    </mitre>
    <group>defense_evasion,timestomping,</group>
  </rule>

  <!-- ======================================== -->
  <!-- DISCOVERY / RECONNAISSANCE               -->
  <!-- ======================================== -->

  <!-- Enumeration commands (individual, low severity) -->
  <rule id="100080" level="6">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(whoami|hostname|ipconfig|systeminfo|nltest|dsquery|arp|netstat|tasklist|qprocess|qwinsta|query)\.exe$</field>
    <description>Discovery: Enumeration command - $(win.eventdata.image) $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1082</id>
      <id>T1016</id>
    </mitre>
    <group>discovery,enumeration,</group>
  </rule>

  <!-- net group/localgroup/user enumeration -->
  <rule id="100081" level="8">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\net1?\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\s+(group|localgroup|user|share|view|session|use\s+\\\\|domain\s+admins|enterprise\s+admins)</field>
    <description>Discovery: AD/network enumeration - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1087</id>
      <id>T1069</id>
    </mitre>
    <group>discovery,ad_enumeration,</group>
  </rule>

  <!-- nltest domain trust enumeration -->
  <rule id="100082" level="8">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\nltest\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(domain_trusts|dclist|dsgetdc|parentdomain)</field>
    <description>Discovery: Domain trust enumeration via nltest - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1482</id>
    </mitre>
    <group>discovery,domain_trust,</group>
  </rule>

  <!-- ======================================== -->
  <!-- IMPACT / RANSOMWARE INDICATORS           -->
  <!-- ======================================== -->

  <!-- bcdedit disabling recovery -->
  <rule id="100090" level="14">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)\\bcdedit\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(recoveryenabled\s+no|bootstatuspolicy\s+ignoreallfailures)</field>
    <description>CRITICAL: Boot recovery disabled via bcdedit - ransomware indicator - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1490</id>
    </mitre>
    <group>impact,ransomware_indicator,</group>
  </rule>

  <!-- Volume shadow copy deletion (ransomware precursor) -->
  <rule id="100091" level="14">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(vssadmin.*delete\s+shadows|wmic.*shadowcopy\s+delete|bcdedit.*recoveryenabled.*no)</field>
    <description>CRITICAL: Shadow copy/recovery deletion - ransomware indicator - $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1490</id>
    </mitre>
    <group>impact,ransomware_indicator,</group>
  </rule>

</group>


